# ===========================================
# SYNOS MEDICAL - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in the values
#
# Variables WITHOUT NEXT_PUBLIC_ prefix are server-side only
# Variables WITH NEXT_PUBLIC_ prefix are exposed to the browser
#
# Site config is read server-side and passed to client via Context

# -------------------------------------------
# SITE CONFIGURATION (Server-side)
# -------------------------------------------
# Primary site URL (with https://, no trailing slash)
SITE_URL=https://www.synos.se
SITE_NAME=Synos Medical
SITE_DESCRIPTION=Sveriges ledande leverantör av MDR-certifierad klinikutrustning för laser, hårborttagning, tatueringsborttagning och hudföryngring.

# Default OG Image (absolute URL or path from site root)
OG_IMAGE=/og-image.jpg

# -------------------------------------------
# COMPANY INFORMATION (Server-side)
# -------------------------------------------
COMPANY_NAME=Synos Medical AB
COMPANY_ORG_NUMBER=556871-8075
COMPANY_EMAIL=info@synos.se
COMPANY_PHONE=010-205 15 01
NOREPLY_EMAIL=noreply@synos.se

# Company Addresses (JSON format)
# Each address: name, street, postalCode, city, country, lat, lng
COMPANY_ADDRESSES='[{"name":"Stockholm","street":"Turebergsvägen 5","postalCode":"19147","city":"Stockholm","country":"Sverige","lat":59.4196154,"lng":17.9620161},{"name":"Linköping","street":"Datalinjen 5","postalCode":"58330","city":"Linköping","country":"Sverige","lat":58.4196154,"lng":15.6620161}]'

# -------------------------------------------
# SOCIAL MEDIA LINKS (Server-side)
# -------------------------------------------
SOCIAL_FACEBOOK=https://www.facebook.com/synosmedical
SOCIAL_INSTAGRAM=https://www.instagram.com/synosmedical
SOCIAL_LINKEDIN=https://www.linkedin.com/company/synos-medical

# -------------------------------------------
# ANALYTICS & TRACKING (Client-side - needs NEXT_PUBLIC)
# -------------------------------------------
# Google Tag Manager ID
NEXT_PUBLIC_GTM_ID=GTM-PQ42DDZ

# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=2886484504973538

# Google Maps API Key (optional - leave empty for development)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Cookiebot ID (optional)
NEXT_PUBLIC_COOKIEBOT_ID=

# Convolo.ai Chat Widget Key
NEXT_PUBLIC_CONVOLO_WIDGET_KEY=

# -------------------------------------------
# AUTHENTICATION (Better Auth)
# -------------------------------------------
# Secret key for Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Base URL for Better Auth (usually same as site URL)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Additional trusted origins (comma-separated, for development/staging)
# Example: https://staging.synos.se,https://preview.synos.se
BETTER_AUTH_TRUSTED_ORIGINS=

# -------------------------------------------
# DATABASE
# -------------------------------------------
# MongoDB connection string (MUST include database name!)
MONGODB_URI=mongodb://127.0.0.1:27017/synos-db?directConnection=true&serverSelectionTimeoutMS=2000
MONGODB_DB=synos-db

# -------------------------------------------
# EMAIL SERVICE
# -------------------------------------------
# Resend API Key (leave empty for development mode - forms work but no emails sent)
RESEND_API_KEY=

# -------------------------------------------
# NODE ENVIRONMENT
# -------------------------------------------
NODE_ENV=development

# Next.js Server Actions Encryption Key (generate with: openssl rand -hex 32)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
